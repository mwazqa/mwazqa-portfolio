{
  "name": "playwright-tests-ts",
  "version": "1.0.0",
  "description": "Unified API and UI tests using Playwright with TypeScript",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:api": "npx playwright test tests/api",
    "test:ui": "npx playwright test tests/ui",
    "report:html": "npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.1",
    "allure-playwright": "^2.0.0",
    "allure-commandline": "^2.14.0"
  }
}

